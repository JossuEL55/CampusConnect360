{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "Jwt": {
    "Issuer": "CampusConnect360",
    "Audience": "CampusConnect360Clients",
    "ExpirationMinutes": 60
  },
  "Auth": {
    "DemoPassword": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "HealthServices": {
    "AcademicService": "http://localhost:5001/api/academic/health",
    "PaymentService": "http://localhost:5002/api/payments/health",
    "AttendanceService": "http://localhost:5003/api/attendance/health",
    "NotificationService": "http://localhost:5004/api/notifications/health",
    "AnalyticsService": "http://localhost:5005/api/analytics/health"
  },
  "ReverseProxy": {
    "Routes": {
      "academic-health-route": {
        "ClusterId": "academic-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": -10,
        "Match": {
          "Path": "/api/academic/health"
        }
      },
      "payments-health-route": {
        "ClusterId": "payments-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": -10,
        "Match": {
          "Path": "/api/payments/health"
        }
      },
      "attendance-health-route": {
        "ClusterId": "attendance-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": -10,
        "Match": {
          "Path": "/api/attendance/health"
        }
      },
      "notifications-health-route": {
        "ClusterId": "notifications-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": -10,
        "Match": {
          "Path": "/api/notifications/health"
        }
      },
      "analytics-health-route": {
        "ClusterId": "analytics-cluster",
        "AuthorizationPolicy": "Anonymous",
        "Order": -10,
        "Match": {
          "Path": "/api/analytics/health"
        }
      },
      "academic-route": {
        "ClusterId": "academic-cluster",
        "AuthorizationPolicy": "AcademicPolicy",
        "Match": {
          "Path": "/api/academic/{**catch-all}"
        }
      },
      "payments-route": {
        "ClusterId": "payments-cluster",
        "AuthorizationPolicy": "FinancePolicy",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      },
      "attendance-route": {
        "ClusterId": "attendance-cluster",
        "AuthorizationPolicy": "TeacherPolicy",
        "Match": {
          "Path": "/api/attendance/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "AuthorizationPolicy": "AuthenticatedPolicy",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "AuthorizationPolicy": "DirectorPolicy",
        "Match": {
          "Path": "/api/analytics/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "academic-cluster": {
        "Destinations": {
          "academic-destination": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "payments-destination": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "attendance-cluster": {
        "Destinations": {
          "attendance-destination": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "notifications-destination": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "analytics-destination": {
            "Address": "http://localhost:5005"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
