#Configuración de la base de datos PostgreSQL
POSTGRES_USER=campus_admin
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=campusconnect
POSTGRES_PORT=5432

##Configuración de RabbitMQ
RABBITMQ_DEFAULT_USER=campus
RABBITMQ_DEFAULT_PASS=rabbit_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

#Configuración de Seq
SEQ_PORT=8081
SEQ_INGESTION_PORT=5341
SEQ_ADMIN_USERNAME=admin
SEQ_ADMIN_PASSWORD=seq_password
GATEWAY_PORT=8080
FRONTEND_PORT=3000

#Configuración de JWT
JWT_SECRET=CHANGE_THIS_DEVELOPMENT_SECRET
JWT_ISSUER=CampusConnect360
JWT_AUDIENCE=CampusConnect360Clients

# Autenticación del Gateway
JWT_SECRET=CHANGE_THIS_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
AUTH_DEMO_PASSWORD=CHANGE_THIS_DEMO_PASSWORD